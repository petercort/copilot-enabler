{
  "name": "copilot-enabler",
  "displayName": "Copilot Enabler",
  "description": "Analyze and improve your GitHub Copilot adoption — discover unused features, get actionable recommendations, and implement them interactively.",
  "version": "0.1.6",
  "publisher": "petercort",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/petercort/copilot-enabler"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "adoption",
    "github",
    "ai",
    "developer-productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotEnabler.analyze",
        "title": "Copilot Enabler: Run Full Analysis",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotEnabler.featureMatrix",
        "title": "Copilot Enabler: Scorecard",
        "icon": "$(graph-line)"
      },
      {
        "command": "copilotEnabler.implement",
        "title": "Copilot Enabler: Implement Recommendation"
      },
      {
        "command": "copilotEnabler.showMe",
        "title": "Copilot Enabler: Show Me Tutorial"
      },
      {
        "command": "copilotEnabler.settings",
        "title": "Copilot Enabler: Settings",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotEnabler",
          "title": "Copilot Enabler",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "copilotEnabler": [
        {
          "id": "copilotEnabler.features",
          "name": "Feature Catalog"
        },
        {
          "id": "copilotEnabler.recommendations",
          "name": "Recommendations"
        }
      ]
    },
    "menus": {
      "commandPalette": [],
      "view/title": [
        {
          "command": "copilotEnabler.analyze",
          "when": "view == copilotEnabler.features || view == copilotEnabler.recommendations",
          "group": "navigation"
        },
        {
          "command": "copilotEnabler.settings",
          "when": "view == copilotEnabler.features || view == copilotEnabler.recommendations",
          "group": "navigation"
        },
        {
          "command": "copilotEnabler.featureMatrix",
          "when": "view == copilotEnabler.features || view == copilotEnabler.recommendations",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "copilotEnabler.implement",
          "when": "view == copilotEnabler.recommendations && viewItem == implementable",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Copilot Enabler",
      "properties": {
        "copilotEnabler.hiddenFeatures": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Feature IDs to hide from analysis, recommendations, and tree views. Use the Settings panel (Copilot Enabler: Settings) to manage hidden features."
        },
        "copilotEnabler.latestVersionChecked": {
          "type": "string",
          "default": "1.123.0",
          "description": "The most recent VS Code release the feature catalog has been reconciled against. Used by the auto-update workflow as a watermark to track which version has been reviewed."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "copilot-enabler-setup",
        "title": "Maximize Your Copilot Usage",
        "description": "Discover and adopt GitHub Copilot features to boost your productivity.",
        "steps": [
          {
            "id": "run-analysis",
            "title": "Run your first analysis",
            "description": "Scan your environment to see which Copilot features you're using.\n[Run Analysis](command:copilotEnabler.analyze)",
            "media": {
              "markdown": "media/walkthrough/run-analysis.md"
            }
          },
          {
            "id": "review-score",
            "title": "Review your adoption score",
            "description": "Check the status bar and dashboard for your overall Copilot adoption score.",
            "media": {
              "markdown": "media/walkthrough/review-score.md"
            }
          },
          {
            "id": "implement-first",
            "title": "Implement your first recommendation",
            "description": "Try a recommended feature with Copilot.\n[Try it](command:copilotEnabler.implement)",
            "media": {
              "markdown": "media/walkthrough/implement.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ --noEmit && node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck:watch": "tsc -p ./ --noEmit --watch",
    "lint": "eslint src/",
    "test": "jest --config jest.config.js",
    "installextension": "node -e \"require('fs').rmSync('out', { recursive: true, force: true });\" && vsce package && code --install-extension copilot-enabler-*.vsix --force",
    "new-feature": "node scripts/new-feature.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "globals": "^17.5.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.0"
  }
}
